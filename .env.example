NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
DATABASE_URL=postgres://user:pass@localhost:5432/feriados
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=172800
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
TRUST_PROXY=true
QUERY_TRACE_ENABLED=true
REAL_IP_HEADER_ORDER=cf-connecting-ip,true-client-ip,x-real-ip,x-forwarded-for,forwarded,fly-client-ip,fastly-client-ip,x-client-ip
STATUS_ENABLED=true
METRICS_ENABLED=true
OPS_ACCESS_TOKEN=
OPS_IP_ALLOWLIST=
CORS_ENABLED=false
CORS_ORIGINS=
CORS_METHODS=GET,HEAD,OPTIONS
CORS_HEADERS=content-type,x-request-id,x-ops-token
CORS_CREDENTIALS=false
CORS_MAX_AGE_SECONDS=86400
